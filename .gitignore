```gitignore
# =========================================================
# Python
# =========================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so


# =========================================================
# Distribution / packaging
# =========================================================

.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST


# =========================================================
# PyInstaller
# =========================================================

*.manifest
*.spec


# =========================================================
# Installer logs
# =========================================================

pip-log.txt
pip-delete-this-directory.txt


# =========================================================
# Unit tests and coverage
# =========================================================

htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/


# =========================================================
# Translations
# =========================================================

*.mo
*.pot


# =========================================================
# Framework-specific files
# =========================================================

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask
instance/
.webassets-cache

# Scrapy
.scrapy

# Sphinx
docs/_build/

# PyBuilder
.pybuilder/
target/


# =========================================================
# Jupyter and IPython
# =========================================================

.ipynb_checkpoints/
profile_default/
ipython_config.py


# =========================================================
# Dependency and package managers
# =========================================================

# pyenv
# .python-version

# Pipenv
# Pipfile.lock

# UV
# uv.lock

# Poetry
# poetry.lock
# poetry.toml

# PDM
# pdm.lock
# pdm.toml
.pdm-python
.pdm-build/

# Pixi
# pixi.lock
.pixi/

# PEP 582
__pypackages__/


# =========================================================
# Background services
# =========================================================

# Celery
celerybeat-schedule
celerybeat.pid

# Redis
*.rdb
*.aof
*.pid

# RabbitMQ
mnesia/
rabbitmq/
rabbitmq-data/

# ActiveMQ
activemq-data/


# =========================================================
# SageMath
# =========================================================

*.sage.py


# =========================================================
# Virtual environments
# =========================================================

.venv/
venv/
env/
ENV/
env.bak/
venv.bak/


# =========================================================
# Environment variables and credentials
# =========================================================

.env
.env.*
!.env.example
.envrc

# General secret and credential files
secrets
secrets.*
secret
secret.*
credentials
credentials.*
credentials.json
service-account.json
service_account.json

# API keys and local configuration
api_keys.*
apikeys.*
*.pem
*.key
*.p12
*.pfx

# Allow safe example files
!secrets.example.toml
!credentials.example.json


# =========================================================
# Streamlit
# =========================================================

.streamlit/secrets.toml
.streamlit/secrets.*
.streamlit/credentials.toml

# Keep other Streamlit configuration files, such as config.toml,
# unless they contain sensitive information.


# =========================================================
# Cloud and service credentials
# =========================================================

# Google Cloud
.gcloud/
application_default_credentials.json

# AWS
.aws/

# Azure
.azure/

# OpenAI or application-specific local configuration
.openai/
openai_config.json


# =========================================================
# IDEs and editors
# =========================================================

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject

# PyCharm / IntelliJ
.idea/

# Visual Studio Code
.vscode/

# Temporary editor files
*.swp
*.swo
*~
tempCodeRunnerFile.py


# =========================================================
# Operating system files
# =========================================================

.DS_Store
Thumbs.db
desktop.ini


# =========================================================
# Documentation and site builds
# =========================================================

site/


# =========================================================
# Static analysis and type checking
# =========================================================

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# pytype
.pytype/

# Ruff
.ruff_cache/


# =========================================================
# Cython
# =========================================================

cython_debug/


# =========================================================
# Other tools
# =========================================================

# Abstra
.abstra/

# PyPI configuration
.pypirc

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/
```
